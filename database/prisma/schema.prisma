generator client {
  provider = "prisma-client"
  output   = "../../backend/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)
  users     User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id              Int                @id @default(autoincrement())
  email           String             @unique @db.Citext
  passwordHash    String             @map("password_hash") @db.VarChar(255)
  roleId          Int                @map("role_id")
  role            Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  loginAttempts   AuthLoginAttempt[]
  deletedPatients Patient[]          @relation("PatientDeletedBy")

  @@index([roleId], map: "users_role_id_idx")
  @@map("users")
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  code      String   @unique @db.VarChar(30)
  address   String?  @db.Text
  patients  Patient[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name], map: "branches_name_idx")
  @@map("branches")
}

model Patient {
  id               Int                     @id @default(autoincrement())
  patientCode      String                  @unique @map("patient_code") @db.VarChar(40)
  fullName         String                  @map("full_name") @db.VarChar(150)
  dateOfBirth      DateTime                @map("date_of_birth") @db.Date
  gender           PatientGender
  branchId         Int                     @map("branch_id")
  branch           Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  registrationDate DateTime                @default(now()) @map("registration_date") @db.Date
  deletedAt        DateTime?               @map("deleted_at")
  deletedBy        Int?                    @map("deleted_by")
  deletedByUser    User?                   @relation("PatientDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)
  deleteReason     String?                 @map("delete_reason") @db.Text
  address          PatientAddress?
  phoneNumbers     PatientPhoneNumber[]
  emergencyContact PatientEmergencyContact?
  insuranceInfo    PatientInsuranceInfo?
  additionalInfo   PatientAdditionalInfo?
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  @@index([branchId, deletedAt], map: "patients_branch_id_deleted_at_idx")
  @@index([branchId, deletedAt, registrationDate], map: "patients_branch_id_deleted_at_registration_date_idx")
  @@index([fullName], map: "patients_full_name_idx")
  @@index([dateOfBirth], map: "patients_date_of_birth_idx")
  @@map("patients")
}

model PatientAddress {
  id           Int      @id @default(autoincrement())
  patientId    Int      @unique @map("patient_id")
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  addressLine1 String   @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  city         String?  @db.VarChar(120)
  province     String?  @db.VarChar(120)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([city], map: "patient_addresses_city_idx")
  @@index([province], map: "patient_addresses_province_idx")
  @@map("patient_addresses")
}

model PatientPhoneNumber {
  id          Int       @id @default(autoincrement())
  patientId   Int       @map("patient_id")
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  phoneType   PhoneType @map("phone_type")
  phoneNumber String    @map("phone_number") @db.VarChar(20)
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([patientId, phoneType], map: "patient_phone_numbers_patient_id_phone_type_key")
  @@index([patientId], map: "patient_phone_numbers_patient_id_idx")
  @@index([phoneNumber], map: "patient_phone_numbers_phone_number_idx")
  @@index([isPrimary, phoneNumber], map: "patient_phone_numbers_is_primary_phone_number_idx")
  @@map("patient_phone_numbers")
}

model PatientEmergencyContact {
  id           Int      @id @default(autoincrement())
  patientId    Int      @unique @map("patient_id")
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fullName     String   @map("full_name") @db.VarChar(150)
  relationship String?  @db.VarChar(100)
  contactNumber String  @map("contact_number") @db.VarChar(20)
  addressLine1 String?  @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  city         String?  @db.VarChar(120)
  province     String?  @db.VarChar(120)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([contactNumber], map: "patient_emergency_contacts_contact_number_idx")
  @@map("patient_emergency_contacts")
}

model PatientInsuranceInfo {
  id                   Int      @id @default(autoincrement())
  patientId            Int      @unique @map("patient_id")
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  healthCardNumber     String?  @map("health_card_number") @db.VarChar(60)
  healthCardVisionCode String?  @map("health_card_vision_code") @db.VarChar(20)
  expiryDate           DateTime? @map("expiry_date") @db.Date
  preferredDoctor      String?  @map("preferred_doctor") @db.VarChar(150)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([healthCardNumber], map: "patient_insurance_info_health_card_number_idx")
  @@map("patient_insurance_info")
}

model PatientAdditionalInfo {
  id          Int      @id @default(autoincrement())
  patientId   Int      @unique @map("patient_id")
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  guardian    String?  @db.VarChar(150)
  referredBy  String?  @map("referred_by") @db.VarChar(150)
  patientNote String?  @map("patient_note") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("patient_additional_info")
}

model AuthLoginAttempt {
  id          BigInt   @id @default(autoincrement())
  userId      Int?     @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String   @db.VarChar(255)
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  isSuccess   Boolean  @default(false) @map("is_success")
  attemptedAt DateTime @default(now()) @map("attempted_at")

  @@index([email, isSuccess, attemptedAt(sort: Desc)], map: "auth_login_attempts_email_is_success_attempted_at_desc_idx")
  @@index([userId, attemptedAt], map: "auth_login_attempts_user_id_attempted_at_idx")
  @@index([isSuccess, attemptedAt], map: "auth_login_attempts_is_success_attempted_at_idx")
  @@map("auth_login_attempts")
}

enum PatientGender {
  MALE
  FEMALE
  OTHER
}

enum PhoneType {
  MOBILE
  BUSINESS
  ADDITIONAL
}
